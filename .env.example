# Example env. Copy to .env and fill. NEVER commit a real .env.

# --- Database (tests use embedded-postgres and ignore these) ---
DATABASE_URL=postgres://vt_app:vt_app@localhost:5432/valvetrade
# Migration/owner role (runs DDL; the app connects as the non-owner vt_app for RLS)
DATABASE_ADMIN_URL=postgres://postgres:postgres@localhost:5432/valvetrade

# --- Data-source credentials (not needed for the walking skeleton; add per connector) ---
DATA_SOURCE_A_API_KEY=
DATA_SOURCE_B_API_KEY=
DATA_SOURCE_C_API_KEY=

# Optional outbound proxy for connectors that need it; empty = direct connection
HTTP_PROXY_URL=
