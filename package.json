{
  "name": "valvetrade",
  "private": true,
  "type": "module",
  "engines": { "node": ">=20" },
  "packageManager": "pnpm@10.32.1",
  "scripts": {
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "migrate": "tsx packages/db/src/migrate.ts",
    "lint": "eslint ."
  },
  "devDependencies": {
    "@types/node": "^22.10.1",
    "@types/pg": "^8.11.10",
    "embedded-postgres": "17.10.0-beta.17",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3",
    "vitest": "^2.1.8"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "@embedded-postgres/windows-x64",
      "@embedded-postgres/linux-x64",
      "@embedded-postgres/darwin-x64",
      "@embedded-postgres/darwin-arm64"
    ]
  }
}
